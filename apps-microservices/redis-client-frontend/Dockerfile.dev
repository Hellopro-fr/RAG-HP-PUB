# Dockerfile for Development Environment

FROM node:20-alpine

# Set the working directory inside the container
WORKDIR /app

# Install pnpm globally
RUN npm install -g pnpm

# Copy only the package manifest and lockfile to leverage Docker's build cache.
# This step will only be re-run if these files change.
COPY package.json pnpm-lock.yaml ./

COPY . .

# Install dependencies. `pnpm install` will use the lockfile to ensure
# consistent dependency versions.
RUN pnpm install

# The source code will be mounted via a volume in docker-compose.
# This CMD will be executed when the container starts.
CMD ["pnpm", "run", "dev"]